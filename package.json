{
  "name": "avento-platform",
  "version": "1.0.0",
  "description": "Avento People Presence Platform - Multi-tenant SaaS for attendance tracking",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
